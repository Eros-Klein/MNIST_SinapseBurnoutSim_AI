---
import background from "../assets/background.svg";
---

<div id="container">
  <img id="background" src={background.src} alt="" fetchpriority="high" />
  <main>
    <!-- Hero -->
    <section id="hero">
      <a href="/" id="logo">
        <svg width="64" height="64" viewBox="0 0 500 200" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="textGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#00f5ff"/>
              <stop offset="50%" stop-color="#7a5cff"/>
              <stop offset="100%" stop-color="#ff4d9d"/>
            </linearGradient>
            <filter id="neonGlow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="6" result="blur1"/>
              <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="blur2"/>
              <feMerge>
                <feMergeNode in="blur1"/>
                <feMergeNode in="blur2"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
          </defs>
          <text
            x="50%" y="60%"
            text-anchor="middle"
            dominant-baseline="middle"
            font-family="Brush Script MT, Pacifico, cursive"
            font-size="220"
            font-weight="600"
            fill="url(#textGradient)"
            filter="url(#neonGlow)"
          >SB</text>
        </svg>
        SynapseBurner
      </a>

      <div id="headline">
        <h1>Is your brain still <span class="gradient-text">firing?</span></h1>
        <p class="subtitle">
          SynapseBurner uses a trained neural network to analyze your still working - or already burnt - Synapses and give you a real-time prediction if it still works.
        </p>
        <div id="cta">
          <button class="btn btn-primary" onclick="window.location.href='/synapse'">
            Check Your Synapses
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </button>
          <a class="btn btn-ghost" href="#">View Past Results</a>
          <a class="btn btn-ghost" href="https://discord.gg/zjCf7cm7" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
            </svg>
            Discord
          </a>
        </div>
      </div>
    </section>
    </main>
</div>

<style>
  /* ── Reset & base ─────────────────────────────── */
  #background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    filter: blur(80px);
    opacity: 0.85;
  }

  #container {
    font-family: Inter, Roboto, "Helvetica Neue", Arial, sans-serif;
    min-height: 100%;
    color: #111827;
  }

  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px 64px;
  }

  /* ── Logo ─────────────────────────────────────── */
  #logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 40px;
    font-size: 22px;
    font-style: italic;
    font-weight: 800;
    color: #7a5cff;
    text-decoration: none;
    letter-spacing: -0.3px;
  }

  /* ── Hero ─────────────────────────────────────── */
  #hero {
    display: flex;
    flex-direction: column;
    padding-top: 16px;
  }

  #headline {
    margin-top: 40px;
  }

  #headline h1 {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin: 0 0 20px;
    color: #0f172a;
  }

  .gradient-text {
    background: linear-gradient(100deg, #00f5ff 0%, #7a5cff 50%, #ff4d9d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 18px;
    line-height: 1.7;
    color: #374151;
    max-width: 620px;
    margin: 0 0 36px;
  }

  /* ── CTA buttons ──────────────────────────────── */
  #cta {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 22px;
    border-radius: 12px;
    font-family: inherit;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    color: #fff;
    background: linear-gradient(83deg, #3245ff 0%, #bc52ee 100%);
    box-shadow:
      0 4px 20px rgba(114, 78, 255, 0.4),
      inset 0 0 0 1px rgba(255, 255, 255, 0.15),
      inset 0 -2px 0 rgba(0, 0, 0, 0.2);
  }

  .btn-primary:hover {
    box-shadow:
      0 8px 28px rgba(114, 78, 255, 0.55),
      inset 0 0 0 1px rgba(255, 255, 255, 0.2);
  }

  .btn-ghost {
    color: #374151;
    background: rgba(255, 255, 255, 0.6);
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.08),
      inset 0 0 0 1px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(8px);
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.85);
  }

  /* ── Divider ──────────────────────────────────── */
  #about {
    margin-top: 72px;
  }

  /* ── About card ───────────────────────────────── */
  .about-card {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 20px;
    padding: 36px 40px;
    margin-bottom: 32px;
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.06);
  }

  .about-card h2 {
    font-size: 22px;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .about-card p {
    font-size: 16px;
    line-height: 1.75;
    color: #374151;
    margin: 0 0 14px;
  }

  .about-card p:last-child {
    margin-bottom: 0;
  }

  .about-card strong {
    color: #111827;
    font-weight: 600;
  }

  /* ── Feature cards ────────────────────────────── */
  #features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .feature-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 16px;
    padding: 28px 24px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.05);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.1);
  }

  .feature-icon {
    font-size: 28px;
    margin-bottom: 14px;
    line-height: 1;
  }

  .feature-card h3 {
    font-size: 16px;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 8px;
  }

  .feature-card p {
    font-size: 14px;
    line-height: 1.65;
    color: #4b5563;
    margin: 0;
  }

  /* ── Responsive ───────────────────────────────── */
  @media screen and (max-width: 640px) {
    #features {
      grid-template-columns: 1fr;
    }

    .about-card {
      padding: 28px 24px;
    }

    #headline h1 {
      font-size: 2rem;
    }
  }
</style>
