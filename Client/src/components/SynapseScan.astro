---
import background from "../assets/background.svg";
---

<div id="container">
  <img id="background" src={background.src} alt="" fetchpriority="high" />
  <main>
    <!-- Hero -->
    <section id="hero">
      <a href="/" id="logo">
        <svg width="64" height="64" viewBox="0 0 500 200" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="textGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#00f5ff"/>
              <stop offset="50%" stop-color="#7a5cff"/>
              <stop offset="100%" stop-color="#ff4d9d"/>
            </linearGradient>
            <filter id="neonGlow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="6" result="blur1"/>
              <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="blur2"/>
              <feMerge>
                <feMergeNode in="blur1"/>
                <feMergeNode in="blur2"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
          </defs>
          <text
            x="50%" y="60%"
            text-anchor="middle"
            dominant-baseline="middle"
            font-family="Brush Script MT, Pacifico, cursive"
            font-size="220"
            font-weight="600"
            fill="url(#textGradient)"
            filter="url(#neonGlow)"
          >SB</text>
        </svg>
        SynapseBurner
      </a>

      <div id="headline">
        <h1>Upload Here!</h1>
        <p class="subtitle">
          Upload an image of your synapse and you will gain real-time results on the health of your synapse!
        </p>

        <div id="upload-area">
          <label id="drop-zone" for="file-input">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <span id="drop-label">Drag & drop or <strong>browse</strong></span>
            <span id="drop-hint">PNG, JPG, WEBP — max 10 MB</span>
            <input id="file-input" type="file" accept="image/png,image/jpeg,image/webp" />
          </label>
          <div hidden="true" id="preview-wrap">
            <img id="preview-img" src="" alt="Preview" />
            <span id="preview-name"></span>
          </div>
        </div>

        <div id="cta">
          <button id="scan-btn" class="btn btn-primary" disabled>
            Scan Synapse
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </button>
          <a class="btn btn-ghost" href="/">Back Home</a>
        </div>
      </div>
    </section>
  </main>
</div>

<script>
  async function scanSynapse(file: File): Promise<void> {
    // TODO: send `file` to the backend API and display results
  }

  const fileInput = document.getElementById("file-input") as HTMLInputElement;
  const scanBtn = document.getElementById("scan-btn") as HTMLButtonElement;
  const dropZone = document.getElementById("drop-zone") as HTMLLabelElement;
  const previewWrap = document.getElementById("preview-wrap") as HTMLDivElement;
  const previewImg = document.getElementById("preview-img") as HTMLImageElement;
  const previewName = document.getElementById("preview-name") as HTMLSpanElement;

  function loadFile(file: File) {
    previewImg.src = URL.createObjectURL(file);
    previewName.textContent = file.name;
    previewWrap.hidden = false;
    previewWrap.style.display = "flex";
    scanBtn.disabled = false;
  }

  fileInput.addEventListener("change", () => {
    const file = fileInput.files?.[0];
    if (file) loadFile(file);
  });

  dropZone.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropZone.classList.add("drag-over");
  });

  dropZone.addEventListener("dragleave", () => {
    dropZone.classList.remove("drag-over");
  });

  dropZone.addEventListener("drop", (e) => {
    e.preventDefault();
    dropZone.classList.remove("drag-over");
    const file = e.dataTransfer?.files[0];
    if (file) loadFile(file);
  });

  scanBtn.addEventListener("click", () => {
    const file = fileInput.files?.[0];
    if (file) scanSynapse(file);
  });
</script>

<style>
  /* ── Reset & base ─────────────────────────────── */
  #background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    filter: blur(80px);
    opacity: 0.85;
  }

  #container {
    font-family: Inter, Roboto, "Helvetica Neue", Arial, sans-serif;
    min-height: 100%;
    color: #111827;
  }

  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px 64px;
  }

  /* ── Logo ─────────────────────────────────────── */
  #logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 40px;
    font-size: 22px;
    font-style: italic;
    font-weight: 800;
    color: #7a5cff;
    text-decoration: none;
    letter-spacing: -0.3px;
  }

  /* ── Hero ─────────────────────────────────────── */
  #hero {
    display: flex;
    flex-direction: column;
    padding-top: 16px;
  }

  #headline {
    margin-top: 40px;
  }

  #headline h1 {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin: 0 0 20px;
    color: #0f172a;
  }

  .gradient-text {
    background: linear-gradient(100deg, #00f5ff 0%, #7a5cff 50%, #ff4d9d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 18px;
    line-height: 1.7;
    color: #374151;
    max-width: 620px;
    margin: 0 0 36px;
  }

  /* ── Upload area ──────────────────────────────── */
  #upload-area {
    margin-bottom: 28px;
  }

  #drop-zone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 40px 32px;
    border-radius: 16px;
    border: 2px dashed rgba(122, 92, 255, 0.45);
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(10px);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    color: #374151;
  }

  #drop-zone:hover,
  #drop-zone.drag-over {
    border-color: #7a5cff;
    background: rgba(122, 92, 255, 0.08);
  }

  #drop-label {
    font-size: 15px;
    font-weight: 500;
  }

  #drop-hint {
    font-size: 12px;
    color: #9ca3af;
  }

  #file-input {
    display: none;
  }

  #preview-wrap {
    display: none;
    align-items: center;
    gap: 14px;
    margin-top: 16px;
    padding: 12px 16px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  #preview-img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  #preview-name {
    font-size: 14px;
    font-weight: 500;
    color: #374151;
    word-break: break-all;
  }

  /* ── CTA buttons ──────────────────────────────── */
  #cta {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 22px;
    border-radius: 12px;
    font-family: inherit;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    color: #fff;
    background: linear-gradient(83deg, #3245ff 0%, #bc52ee 100%);
    box-shadow:
      0 4px 20px rgba(114, 78, 255, 0.4),
      inset 0 0 0 1px rgba(255, 255, 255, 0.15),
      inset 0 -2px 0 rgba(0, 0, 0, 0.2);
  }

  .btn-primary:hover {
    box-shadow:
      0 8px 28px rgba(114, 78, 255, 0.55),
      inset 0 0 0 1px rgba(255, 255, 255, 0.2);
  }

  .btn-ghost {
    color: #374151;
    background: rgba(255, 255, 255, 0.6);
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.08),
      inset 0 0 0 1px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(8px);
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.85);
  }

  .btn-primary:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  /* ── Divider ──────────────────────────────────── */
  #about {
    margin-top: 72px;
  }

  /* ── About card ───────────────────────────────── */
  .about-card {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 20px;
    padding: 36px 40px;
    margin-bottom: 32px;
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.06);
  }

  .about-card h2 {
    font-size: 22px;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .about-card p {
    font-size: 16px;
    line-height: 1.75;
    color: #374151;
    margin: 0 0 14px;
  }

  .about-card p:last-child {
    margin-bottom: 0;
  }

  .about-card strong {
    color: #111827;
    font-weight: 600;
  }

  /* ── Feature cards ────────────────────────────── */
  #features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .feature-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 16px;
    padding: 28px 24px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.05);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.1);
  }

  .feature-icon {
    font-size: 28px;
    margin-bottom: 14px;
    line-height: 1;
  }

  .feature-card h3 {
    font-size: 16px;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 8px;
  }

  .feature-card p {
    font-size: 14px;
    line-height: 1.65;
    color: #4b5563;
    margin: 0;
  }

  /* ── Responsive ───────────────────────────────── */
  @media screen and (max-width: 640px) {
    #features {
      grid-template-columns: 1fr;
    }

    .about-card {
      padding: 28px 24px;
    }

    #headline h1 {
      font-size: 2rem;
    }
  }
</style>
